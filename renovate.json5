{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "docker:enableMajor",
    ":separateMultipleMajorReleases"
  ],
  "enabled": true,
  "timezone": "Europe/Berlin",
  "prConcurrentLimit": 6,
  "prHourlyLimit": 2,
  "prCreation": "immediate",
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "customManagers": [
    {
      // Bump the pinned OpenSubsonic OpenAPI commit in gen.go whenever
      // upstream's main branch moves. The SHA is embedded in the
      // `//go:generate` tar-fetch URL; Renovate rewrites it on main
      // commits via the git-refs datasource.
      "customType": "regex",
      "managerFilePatterns": ["/^internal/subsonic/gen\\.go$/"],
      "matchStrings": [
        "open-subsonic-api/archive/(?<currentDigest>[a-f0-9]{40})\\.tar\\.gz"
      ],
      "depNameTemplate": "https://github.com/opensubsonic/open-subsonic-api",
      "datasourceTemplate": "git-refs",
      "currentValueTemplate": "main"
    }
  ],
  "packageRules": [
    {
      "groupName": "Frontend Core",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "vue", "@vue/**",
        "vite", "@vitejs/**",
        "typescript", "@typescript-eslint/**", "vue-tsc",
        "tailwindcss", "@tailwindcss/**"
      ],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "groupName": "OpenCloud SDK",
      "matchManagers": ["npm"],
      "matchPackageNames": ["@opencloud-eu/**"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "groupName": "QA & Dev Tools",
      "matchPackageNames": [
        "vitest", "@vitest/**", "happy-dom",
        "eslint", "prettier"
      ],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "groupName": "Go Dependencies",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "groupName": "Docker Images",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "breaking"]
    }
  ]
}

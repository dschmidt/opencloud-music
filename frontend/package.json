{
  "name": "opencloud-music",
  "version": "0.0.0",
  "private": true,
  "description": "OpenCloud Music — OpenSubsonic-compatible music server for OpenCloud",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "serve": "vite",
    "build": "vite build",
    "check:types": "vue-tsc --noEmit",
    "lint": "eslint 'src/**/*.{js,ts,vue}' --color",
    "format:check": "prettier . --check",
    "format:write": "prettier . --write",
    "test:unit": "NODE_OPTIONS=--unhandled-rejections=throw vitest"
  },
  "devDependencies": {
    "@opencloud-eu/design-system": "6.1.0",
    "@opencloud-eu/eslint-config": "6.1.0",
    "@opencloud-eu/extension-sdk": "6.1.0",
    "@opencloud-eu/prettier-config": "6.1.0",
    "@opencloud-eu/tsconfig": "6.1.0",
    "@opencloud-eu/web-client": "6.1.0",
    "@opencloud-eu/web-pkg": "6.1.0",
    "@types/node": "24.12.0",
    "@vue/compiler-dom": "3.5.31",
    "@vue/server-renderer": "3.5.31",
    "@vue/test-utils": "2.4.6",
    "eslint": "10.0.3",
    "happy-dom": "20.8.9",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vite": "8.0.3",
    "vitest": "3.2.4",
    "vue": "3.5.31",
    "vue-tsc": "3.2.5"
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "overrides": {
      "@module-federation/vite": "1.14.1"
    }
  }
}

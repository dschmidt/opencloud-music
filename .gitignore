# Bootstrap scratch dir — clones, built binaries, runtime state,
# generated SDK, logs, TLS cert. All regenerated by ./bootstrap.sh.
/bootstrap/

# Go
/backend/bin/
/backend/opencloud-music
/backend/bundle-openapi

# Subsonic server stubs — generated from pinned OpenSubsonic OpenAPI spec.
# Regenerated from the host via `make backend-generate` or in CI before build.
/backend/internal/subsonic/model/generated.go
/backend/internal/subsonic/model/.cache/

# Frontend
/frontend/node_modules/
/frontend/dist/
/frontend/.vite/
/frontend/.__mf__temp/

# Docs build — scratch clones + synthesized Docusaurus site.
# Regenerated by `make docs`; never committed.
.github/docs/.cache/
docs/generated/

# Environment / secrets
.env

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/
.claude/
